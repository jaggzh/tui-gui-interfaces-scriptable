          q{SERVICE=$(printf "auth\nbilling\nsearch\n" | gum choose --header "Tail logs for which service?"); gum log --level info "Pretending to tail logs" service "$SERVICE"},
          q{TASK=$(printf "Refactor cache invalidation\nWrite migration\nRename the variable called stuff\n" | gum choose --header "Pick today's dragon"); echo "Working on: $TASK"},
          q{printf "coffee\ntea\nthat one sparkling water nobody admits buying\n" | gum choose --no-limit --header "Office restock"},
          { cmd => q{TMUXSESS=$(tmux list-sessions -F \#S | gum filter --placeholder "Pick session..."); tmux switch-client -t "$TMUXSESS" || tmux attach -t "$TMUXSESS"}, note => 'Requires tmux and at least one session; inside tmux it switches, otherwise it tries to attach.' },
          q{ACTION=$(printf "ship\nrollback\nwalk away slowly\n" | gum choose --header "What now?"); echo "Action: $ACTION"},
        ],
        detect => 'gum',
      },
    ],
  },

  {
    section => 'GUI-Application-Launcher',
    items => [
      {
        name => 'rofi',
        blurb => 'robust X11/Wayland launcher; powerful -dmenu mode.',
        features => [
          'Run/ssh/window/file modi; themeable',
          'dmenu mode for scriptable prompts (stdin list → stdout selection)',
          'Type-to-filter, multi-select, custom keybindings, plugins',
        ],
        examples => [
          q{printf "build\nrun\ntest\n" | rofi -dmenu -p "Action"},
          q{rofi -show run},
          q{printf "apple\nbanana\ncherry\n" | rofi -dmenu -multi-select -p "Pick"},
        ],
        detect => 'rofi',
      },
      {
        name => 'wofi',
        blurb => 'Wayland (wlroots) launcher; has dmenu mode.',
        features => [
          'Wayland-native with CSS theming',
          'dmenu mode (stdin list → stdout choice)',
          'Normal window fallback if compositor lacks layer-shell',
        ],
        examples => [
          q{printf "one\ntwo\nthree\n" | wofi --show dmenu},
          q{wofi --show run},
        ],
        detect => 'wofi',
      },
      {
        name => 'dmenu',
        blurb => 'ultra-minimal X11 dmenu; blazing fast text prompt.',
        features => [
          'stdin list → interactive filter → stdout selection',
          'Script-friendly; tiny deps; often bound to hotkeys',
        ],
        examples => [
          q{printf "alpha\nbeta\ngamma\n" | dmenu -p "Pick"},
          q{cmd=$(printf "xterm\nkonsole\nkate\n" | dmenu -p "Launch"); [ -n "$cmd" ] && $cmd &},
        ],
        detect => 'dmenu',
      },
    ],
  },
];

# ---------- helpers ----------
sub have($cmd) { system("command -v $cmd >/dev/null 2>&1") == 0; }

sub header($t){ say "\n== $clrhead$t$rst ==" }

sub list_sections($data){
  say "Sections:";
  my $i = 1;
  for my $sec (@$data){
    say "$clrsel$i$clrsep.$rst $$sec{section}";
    $i++;
  }
  say "${clrsel}q$clrsep.$rst Exit";
}

sub list_items($sec){
  header $$sec{section};
  my $i = 1;
  for my $it (@{$$sec{items}}){
    my $installed = have($$it{detect}) ? "" : " $clrnotinst(not installed)$rst";
    say "$clrsel$i$clrsep.$rst $clrname$$it{name}$rst$installed: $$it{blurb}";
    say "   Features: " . join("; ", @{$$it{features}});
    $i++;
  }
  say "${clrsel}ENTER$clrsep.$rst Back";
}

sub ex_cmd($ex){
  return ref($ex) eq 'HASH' ? $$ex{cmd} : $ex;
}

sub ex_note($ex){
  return ref($ex) eq 'HASH' ? ($$ex{note} // '') : '';
}

sub detect_clipboard_tools(){
  $has_xclip = have('xclip') ? 1 : 0;
  $has_xsel  = have('xsel')  ? 1 : 0;

  if (!defined $cb_bin) {
    $cb_bin = $has_xsel ? 'xsel' : $has_xclip ? 'xclip' : undef;
    return;
  }

  if ($cb_bin eq 'xsel' && !$has_xsel) {
    $cb_bin = $has_xclip ? 'xclip' : undef;
    return;
  }

  if ($cb_bin eq 'xclip' && !$has_xclip) {
    $cb_bin = $has_xsel ? 'xsel' : undef;
    return;
  }
}

sub clipboard_backend(){
  return $cb_bin;
}

sub clipboard_backend_label($name){
  return $name ? "$whi$name$rst" : "${yel}none$rst";
}

sub clipboard_tool_status($name){
  return "${yel}not installed$rst" if !$name || !have($name);
  return clipboard_backend() && clipboard_backend() eq $name
    ? "${bgre}active$rst"
    : "${gre}available$rst";
}

sub toggle_clipboard_backend(){
  detect_clipboard_tools();

  if (!$has_xclip && !$has_xsel) {
    return (0, "Neither xclip nor xsel are installed. Copy to clipboard won't function (try mouse selection/RMB)");
  }

  if ($cb_bin && $cb_bin eq 'xsel') {
    return (0, 'Sorry, xclip was not found on your system.') if !$has_xclip;
    $cb_bin = 'xclip';
    return (1, 'Clipboard backend set to xclip.');
  }

  if ($cb_bin && $cb_bin eq 'xclip') {
    return (0, 'Sorry, xsel was not found on your system.') if !$has_xsel;
    $cb_bin = 'xsel';
    return (1, 'Clipboard backend set to xsel.');
  }

  $cb_bin = $has_xsel ? 'xsel' : 'xclip';
  return (1, "Clipboard backend set to $cb_bin.");
}

sub copy_text($text, $mode='clipboard', $backend=undef){
  detect_clipboard_tools();
  $backend //= clipboard_backend();
  return (0, "Neither xclip nor xsel are installed. Copy to clipboard won't function (try mouse selection/RMB)") if !$backend;
  return (0, 'Sorry, xclip was not found on your system.') if $backend eq 'xclip' && !$has_xclip;
  return (0, 'Sorry, xsel was not found on your system.')  if $backend eq 'xsel'  && !$has_xsel;

  if ($mode eq 'all') {
    my @done;
    for my $sel (qw(primary secondary clipboard)) {
      my ($ok, undef) = copy_text($text, $sel, $backend);
      push @done, $sel if $ok;
    }
    return @done ? (1, "$backend → " . join(', ', @done)) : (0, "$backend copy failed");
  }

  if ($backend eq 'xclip') {
    open my $fh, '|-', 'xclip', '-selection', $mode or return (0, 'failed to start xclip');
    print {$fh} $text;
    close $fh;
    return ($? == 0, "$backend → $mode");
  }

  if ($backend eq 'xsel') {
    my %opt = (
      primary   => '-p',
      secondary => '-s',
      clipboard => '-b',
    );
    open my $fh, '|-', 'xsel', '--input', ($opt{$mode} // '-b') or return (0, 'failed to start xsel');
    print {$fh} $text;
    close $fh;
    return ($? == 0, "$backend → $mode");
  }

  return (0, 'no clipboard backend available');
}

sub show_message($msg){
  say "
[$msg]  (Press Enter)";
  scalar <STDIN>;
}

sub list_examples($it){
  header "$$it{name} — examples";
  my $i = 1;
  for my $ex (@{$$it{examples}}){
    say "$clrsel$i$clrsep)$rst " . ex_cmd($ex);
    my $note = ex_note($ex);
    say "   ${yel}note:$rst $note" if length $note;
    $i++;
  }
  detect_clipboard_tools();
  say "${clrsel}cN$clrsep)$rst Copy example N to clipboard via " . clipboard_backend_label($cb_bin);
  say "${clrsel}xN$clrsep)$rst Copy example N to primary + secondary + clipboard via " . clipboard_backend_label($cb_bin);
  say "${clrsel}x$clrsep)$rst Toggle clipboard backend: xsel [" . clipboard_tool_status('xsel') . "], xclip [" . clipboard_tool_status('xclip') . "]";
  say "${clrsel}ENTER$clrsep)$rst Back";
}

sub prompt($msg){
  print "$yel$msg$rst ";
  my $ans = <STDIN>;
  return undef if !defined $ans;
  chomp $ans;
  return $ans;
}

sub run_cmd($cmd){
  say "
\$ $clrcmd$cmd$rst";
  system('bash', '-c', $cmd);
  show_message("exit code: $?" );
}

# ---------- UI flow ----------
detect_clipboard_tools();
while (1){
  list_sections($catalog);
  my $s = prompt("Pick a section number:");
  exit 0 if !defined $s || ($s//'') eq 'q';
  if ($s !~ /^\d+$/ || $s < 1 || $s > @$catalog) {
    show_message("Invalid section: $s");
    next;
  }

  my $sec = $$catalog[$s-1];
  while (1){
    list_items($sec);
    my $i = prompt("Pick a tool to try examples:");
    last if !defined $i || ($i//'') eq '';
    if ($i !~ /^\d+$/ || $i < 1 || $i > @{$$sec{items}}) {
      show_message("Invalid tool: $i");
      next;
    }

    my $it = $$sec{items}[$i-1];
    while (1){
      list_examples($it);
      my $e = prompt("Run which example? (number, cN, x, xN, eg. c12<enter>)");
      last if !defined $e || ($e//'') eq '';

      if (lc($e) eq 'x') {
        my ($ok, $msg) = toggle_clipboard_backend();
        show_message($msg);
        next;
      }

      if ($e =~ /^([cx])(\d+)$/i) {
        my ($mode, $n) = (lc($1), $2);
        if ($n < 1 || $n > @{$$it{examples}}) {
          show_message("Invalid example number: $n");
          next;
        }
        my $cmd = ex_cmd($$it{examples}[$n-1]);
        my ($ok, $msg) = copy_text($cmd, $mode eq 'c' ? 'clipboard' : 'all');
        show_message(($ok ? "copied: $msg" : $msg));
        next;
      }

      if ($e !~ /^\d+$/ || $e < 1 || $e > @{$$it{examples}}) {
        show_message("Invalid input: $e");
        next;
      }
      my $cmd = ex_cmd($$it{examples}[$e-1]);
      if (!have($$it{detect})){
        show_message("$$it{name} not installed. Try: sudo apt install $$it{detect}");
        next;
      }
      run_cmd($cmd);
    }
  }
}
