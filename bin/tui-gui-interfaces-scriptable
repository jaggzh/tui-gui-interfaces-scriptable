#!/usr/bin/env perl
use v5.36;

# Built-in ANSI color palette; no external color module required.
# Reset also clears bold/bright state.
my $rst  = "\e[0m";

# base colors
my $red  = "\e[31m";
my $gre  = "\e[32m";
my $bro  = "\e[33m";
my $blu  = "\e[34m";
my $mag  = "\e[35m";
my $cya  = "\e[36m";
my $gra  = "\e[90m";

# bright/bold colors
my $bred = "\e[31;1m";
my $bgre = "\e[32;1m";
my $yel  = "\e[33;1m";   # bright brown/yellow
my $bblu = "\e[34;1m";
my $bmag = "\e[35;1m";
my $bcya = "\e[36;1m";
my $whi  = "\e[37;1m";   # bright gray/white

# background colors (base palette names)
my $bgred = "\e[41m";
my $bggre = "\e[42m";
my $bgbro = "\e[43m";
my $bgblu = "\e[44m";
my $bgmag = "\e[45m";
my $bgcya = "\e[46m";
my $bggra = "\e[100m";

# Quick-pick UI helpers for Debian/KDE projects
# - Sections: GUI / TUI / GUI-Application-Launcher
# - Sorted by robustness in each section
# - Shows concise feature overviews and runnable one-line examples
#
# Hints:
# - Press the number to drill in; press the example number to run it
# - In example lists, cN copies example N to the clipboard, x toggles xsel/xclip, and xN copies example N to all X selections
# - We try to detect whether a tool is installed and annotate the list
# - Uses `//` for definedness, and "$$href{k}" style where needed

my $clrcmd = $bcya;
my $clrsel = $bcya;
my $clrsep = $yel;
my $clrhead = $whi;
my $clrname = $whi;
my $clrprompt = $whi;
my $clrnotinst = $yel;

my $has_xclip = 0;
my $has_xsel  = 0;
my $cb_bin;


